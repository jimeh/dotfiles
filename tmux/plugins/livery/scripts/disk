#!/usr/bin/env bash

set -u

path="${1:-/}"

# Last line's 4th field is available KB; the header line is read first
# and harmlessly overwritten. -P keeps each filesystem on one line.
avail=''
while read -r _ _ _ field _; do
  avail="$field"
done < <(df -kP "$path" 2> /dev/null)

case "$avail" in
  '' | *[!0-9]*)
    printf -- '--\n'
    exit 0
    ;;
esac

bytes=$((avail * 1024))

units=(B K M G T P)
div=1
i=0
while [ "$((bytes / div))" -ge 1024 ] && [ "$i" -lt 5 ]; do
  div=$((div * 1024))
  i=$((i + 1))
done

if [ "$((bytes / div))" -ge 10 ] || [ "$i" -eq 0 ]; then
  printf '%s%s\n' "$(((bytes + div / 2) / div))" "${units[i]}"
else
  tenths=$(((bytes * 10 + div / 2) / div))
  printf '%s.%s%s\n' "$((tenths / 10))" "$((tenths % 10))" "${units[i]}"
fi
