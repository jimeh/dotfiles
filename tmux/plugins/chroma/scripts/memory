#!/usr/bin/env bash

set -u

memory_macos() {
  # Matches Activity Monitor's "Memory Used": app memory (anonymous
  # minus purgeable) plus wired and compressed pages.
  local total page_size anon purgeable wired compressed
  local line value used

  total="$(sysctl -n hw.memsize 2> /dev/null)"

  page_size=''
  anon=''
  purgeable=''
  wired=''
  compressed=''
  while IFS= read -r line; do
    value="${line##* }"
    value="${value%.}"
    case "$line" in
      *'page size of'*)
        page_size="${line#*page size of }"
        page_size="${page_size%% *}"
        ;;
      'Anonymous pages:'*) anon="$value" ;;
      'Pages purgeable:'*) purgeable="$value" ;;
      'Pages wired down:'*) wired="$value" ;;
      'Pages occupied by compressor:'*) compressed="$value" ;;
    esac
  done < <(vm_stat 2> /dev/null)

  if [ -n "$total" ] && [ "$total" -gt 0 ] && [ -n "$page_size" ] &&
    [ -n "$anon" ] && [ -n "$purgeable" ] && [ -n "$wired" ] &&
    [ -n "$compressed" ]; then
    used=$(((anon - purgeable + wired + compressed) * page_size))
    printf '%s%%\n' "$(((used * 100 + total / 2) / total))"
  else
    printf -- '--\n'
  fi
}

memory_linux() {
  local key value total available

  total=''
  available=''
  while read -r key value _; do
    case "$key" in
      MemTotal:) total="$value" ;;
      MemAvailable:) available="$value" ;;
    esac
    if [ -n "$total" ] && [ -n "$available" ]; then
      break
    fi
  done < /proc/meminfo

  if [ -n "$total" ] && [ -n "$available" ] && [ "$total" -gt 0 ]; then
    printf '%s%%\n' "$((((total - available) * 100 + total / 2) / total))"
  else
    printf -- '--\n'
  fi
}

case "$OSTYPE" in
  darwin*) memory_macos ;;
  linux*) memory_linux ;;
  *) printf -- '--\n' ;;
esac
