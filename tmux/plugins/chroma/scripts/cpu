#!/usr/bin/env bash

set -u

cpu_macos() {
  # top -l 1 reports a since-boot average and burns ~2s of CPU per call.
  # Sum the per-process decaying averages from ps instead (~35ms) and
  # normalize by core count. Track sums in tenths of a percent so the
  # math stays integer-only.
  local pc int frac sum count ncpu pct

  sum=0
  count=0
  while read -r pc; do
    int="${pc%%.*}"
    frac="${pc#*.}"
    [ "$frac" = "$pc" ] && frac=0
    sum=$((sum + int * 10 + ${frac:0:1}))
    count=$((count + 1))
  done < <(ps -A -o %cpu= 2> /dev/null)

  ncpu="$(sysctl -n hw.ncpu 2> /dev/null)"
  if [ "$count" -eq 0 ] || [ -z "$ncpu" ] || [ "$ncpu" -le 0 ]; then
    printf -- '--\n'
    return
  fi

  pct=$(((sum + ncpu * 5) / (ncpu * 10)))
  [ "$pct" -gt 100 ] && pct=100
  printf '%s%%\n' "$pct"
}

cpu_linux() {
  # Prefer tmpfs-backed locations so the frequent state writes stay in
  # memory ($XDG_RUNTIME_DIR is also per-user and cleared on reboot).
  local state_dir="${XDG_RUNTIME_DIR:-/dev/shm}"
  [ -d "$state_dir" ] || state_dir="${TMPDIR:-/tmp}"
  local state_file="$state_dir/chroma-cpu-${USER:-user}"
  local user nice system idle iowait irq softirq steal
  local idle_all non_idle total now pct
  local prev_total prev_idle prev_time last_pct
  local total_delta idle_delta used_delta

  read -r _ user nice system idle iowait irq softirq steal _ < /proc/stat
  printf -v now '%(%s)T' -1

  idle_all=$((idle + iowait))
  non_idle=$((user + nice + system + irq + softirq + steal))
  total=$((idle_all + non_idle))

  prev_total="$total"
  prev_idle="$idle_all"
  prev_time=0
  last_pct=''
  if [ -r "$state_file" ]; then
    read -r prev_total prev_idle prev_time last_pct < "$state_file" || :
  fi

  # tmux spawns this once per attached client, so invocations can land
  # milliseconds apart. A sub-second /proc/stat window holds only a few
  # scheduler ticks — mostly the cost of spawning this very script — and
  # reads as bogus spikes (50%/100%). Serve the cached value instead.
  if [ -n "$last_pct" ] && [ $((now - prev_time)) -lt 2 ]; then
    printf '%s\n' "$last_pct"
    return
  fi

  total_delta=$((total - prev_total))
  idle_delta=$((idle_all - prev_idle))

  if [ "$total_delta" -le 0 ]; then
    pct='0%'
  else
    used_delta=$((total_delta - idle_delta))
    if [ "$used_delta" -lt 0 ]; then
      used_delta=0
    elif [ "$used_delta" -gt "$total_delta" ]; then
      used_delta="$total_delta"
    fi
    pct="$(((used_delta * 100 + total_delta / 2) / total_delta))%"
  fi

  # A torn read of this single small write is possible but benign: the
  # reader falls back to zeroed prev values and shows one lifetime-average
  # sample. Not worth the extra mv fork to rename into place.
  printf '%s %s %s %s\n' "$total" "$idle_all" "$now" "$pct" > "$state_file"

  printf '%s\n' "$pct"
}

case "$OSTYPE" in
  darwin*) cpu_macos ;;
  linux*) cpu_linux ;;
  *) printf -- '--\n' ;;
esac
