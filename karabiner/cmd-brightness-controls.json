    {
      "from": {
        "key_code": "f1",
        "modifiers": {
          "mandatory": [
            "command"
          ],
          "optional": [
            "caps_lock"
          ]
        }
      },
      "to": [
        {
          "consumer_key_code": "display_brightness_decrement"
        }
      ],
      "type": "basic"
    },
    {
      "from": {
        "key_code": "f2",
        "modifiers": {
          "mandatory": [
            "command"
          ],
          "optional": [
            "caps_lock"
          ]
        }
      },
      "to": [
        {
          "consumer_key_code": "display_brightness_increment"
        }
      ],
      "type": "basic"
    }
  ]
}
